# --- Database (Vercel/Neon Postgres) ---
# Vercel の Storage で Neon Postgres を作成すると自動で設定される変数
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"
# Prisma の migrate / db push 用（プール経由でない直接接続）。Neon では DATABASE_URL_UNPOOLED が入る
DIRECT_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js (NextAuth) ---
# `openssl rand -base64 32` などで生成
AUTH_SECRET="replace-with-a-random-secret"
# 本番では Vercel が自動で URL を判定するため通常は不要。ローカルでは任意。
# AUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Google Cloud Console > APIとサービス > 認証情報 で作成
AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxxxxxxx"

# --- Vercel Blob (ファイル添付) ---
# Vercel の Storage で Blob を作成すると自動で設定される
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
